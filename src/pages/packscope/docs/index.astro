---
// src/pages/packscope/docs/index.astro
// Packscope docs overview page (default locale: en).
import DocsLayout from '../../../components/DocsLayout.astro';
import { getLocalizedDocIndex } from '../../../lib/content';
import { buildAlternates } from '../../../lib/i18n';

const page = await getLocalizedDocIndex('packscope', 'en', '/packscope/docs');
if (!page) return Astro.redirect('/packscope');
const { Content, title, description, navItems, isFallback } = page;
const alternates = buildAlternates('/packscope/docs');
---

<DocsLayout
  title={title}
  description={description}
  sidebarTitle="Packscope Docs"
  navItems={navItems}
  locale="en"
  isFallback={isFallback}
  basePath="/packscope/docs"
  alternates={alternates}
>
  <Content />
</DocsLayout>
