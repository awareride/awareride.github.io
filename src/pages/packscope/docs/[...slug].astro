---
// src/pages/packscope/docs/[...slug].astro
// Catch-all route for Packscope docs — renders Markdown from src/content/docs/
import DocsLayout from '../../../components/DocsLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs
    .filter(doc => doc.id !== 'index')
    .map(doc => ({
      params: { slug: doc.id },
      props: { doc },
    }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
const title = doc.data.title;
const description = doc.data.description;
---

<DocsLayout title={title} description={description}>
  <h1>{title}</h1>
  <Content />
</DocsLayout>
