---
// src/pages/packscope/docs/[...slug].astro
// Catch-all route for Packscope docs (default locale: en, no URL prefix).
import DocsLayout from '../../../components/DocsLayout.astro';
import { getLocalizedPaths, renderLocalizedPage } from '../../../lib/content';
import { buildAlternates } from '../../../lib/i18n';

export async function getStaticPaths() {
  return getLocalizedPaths('packscope', '/packscope/docs', 'en');
}

const { slug } = Astro.props;
const page = await renderLocalizedPage('packscope', 'en', slug, '/packscope/docs');
if (!page) return Astro.redirect('/packscope/docs');
const { Content, title, description, navItems, isFallback } = page;
const alternates = buildAlternates(`/packscope/docs/${slug}`);
---

<DocsLayout
  title={title}
  description={description}
  sidebarTitle="Packscope Docs"
  navItems={navItems}
  locale="en"
  isFallback={isFallback}
  basePath="/packscope/docs"
  alternates={alternates}
>
  <Content />
</DocsLayout>
