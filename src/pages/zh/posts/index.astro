---
// src/pages/zh/posts/index.astro
// Blog listing page (locale: zh). Posts without a Chinese version fall back
// to the English content and are marked on the card.
import Layout from '../../../components/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import PostCard from '../../../components/PostCard.astro';
import { getLocalizedPosts } from '../../../lib/content';
import { buildAlternates } from '../../../lib/i18n';

const items = await getLocalizedPosts('zh');
const sorted = items.sort(
  (a, b) => b.entry.data.date.getTime() - a.entry.data.date.getTime(),
);
const alternates = buildAlternates('/posts');

function dirname(id: string) {
  const parts = id.split('/');
  return parts.length > 1 ? parts.slice(0, -1).join('/') : null;
}
---

<Layout
  title="博客"
  description="AwareRide 团队的技术文章 —— 以觉察之心构建工具。"
  locale="zh"
  alternates={alternates}
>
  <Nav alternates={alternates} />

  <main>
    <section class="hero" style="padding-bottom: 2rem;">
      <div class="container">
        <p class="eyebrow">博客</p>
        <h1>文章</h1>
        <p class="hero-lead" style="margin-top: 0.5rem;">
          关于开发工具、bundle 分析、感知,以及以觉察之心构建的思考。
        </p>
      </div>
    </section>

    <section class="section" style="padding-top: 1rem;">
      <div class="container">
        {
          sorted.length === 0 ? (
            <p style="text-align:center; color:var(--color-text-muted);">
              暂无文章,敬请期待。
            </p>
          ) : (
            <div class="posts-grid">
              {sorted.map(({ entry, isFallback }) => (
                <PostCard
                  title={entry.data.title}
                  date={entry.data.date}
                  description={entry.data.description}
                  tags={entry.data.tags}
                  slug={entry.id}
                  source={dirname(entry.id)}
                  isFallback={isFallback}
                  locale="zh"
                />
              ))}
            </div>
          )
        }
      </div>
    </section>
  </main>

  <Footer />
</Layout>
