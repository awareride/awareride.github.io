---
// src/pages/zh/index.astro
// Landing Page (locale: zh). Copy lives in lib/i18n.ts `home.zh`.
import Layout from '../../components/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import { getLocalizedPosts } from '../../lib/content';
import { home, localizePath, buildAlternates } from '../../lib/i18n';

const c = home.zh;
const items = await getLocalizedPosts('zh');
const latestPosts = items
  .sort((a, b) => b.entry.data.date.getTime() - a.entry.data.date.getTime())
  .slice(0, 3);
const alternates = buildAlternates('/');
---

<Layout title={c.title} description={c.description} locale="zh" alternates={alternates}>
  <Nav alternates={alternates} />

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="container">
        <p class="eyebrow">{c.eyebrow}</p>
        <h1 class="hero-title">
          {c.heroTitleA}<br />
          <span class="gradient-text">{c.heroTitleB}</span>
        </h1>
        <p class="hero-lead">{c.heroLead}</p>
        <div class="hero-actions">
          <a href="https://github.com/awareride" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
            {c.ctaGithub}
          </a>
          <a href="#projects" class="btn btn-secondary">{c.ctaProjects}</a>
        </div>
      </div>
    </section>

    <!-- Latest Posts -->
    {
      latestPosts.length > 0 && (
        <section class="section">
          <div class="container">
            <div class="section-header">
              <p class="eyebrow">{c.latestEyebrow}</p>
              <h2>{c.latestTitle}</h2>
            </div>
            <div class="posts-grid">
              {latestPosts.map(({ entry, isFallback }) => (
                <PostCard
                  title={entry.data.title}
                  date={entry.data.date}
                  description={entry.data.description}
                  tags={entry.data.tags}
                  slug={entry.id}
                  source={null}
                  isFallback={isFallback}
                  locale="zh"
                />
              ))}
            </div>
            <div style="text-align:center; margin-top:2rem;">
              <a href={localizePath('/posts', 'zh')} class="btn btn-secondary">{c.allPosts}</a>
            </div>
          </div>
        </section>
      )
    }

    <!-- About -->
    <section id="about" class="section section-alt">
      <div class="container">
        <div class="section-header">
          <p class="eyebrow">{c.focusEyebrow}</p>
          <h2>{c.focusTitle}</h2>
          <p class="section-lead">{c.focusLead}</p>
        </div>
        <div class="cards-grid">
          <article class="card">
            <div class="card-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"/><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/>
              </svg>
            </div>
            <h3>{c.card1Title}</h3>
            <p>{c.card1Body}</p>
          </article>
          <article class="card">
            <div class="card-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="3"/><path d="M2 8h20M8 2v20"/>
              </svg>
            </div>
            <h3>{c.card2Title}</h3>
            <p>{c.card2Body}</p>
          </article>
          <article class="card">
            <div class="card-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z"/><path d="M12 7v5l3 3"/>
              </svg>
            </div>
            <h3>{c.card3Title}</h3>
            <p>{c.card3Body}</p>
          </article>
        </div>
      </div>
    </section>

    <!-- Projects -->
    <section id="projects" class="section">
      <div class="container">
        <div class="section-header">
          <p class="eyebrow">{c.projectsEyebrow}</p>
          <h2>{c.projectsTitle}</h2>
        </div>
        <div class="project-card">
          <div class="project-info">
            <div class="project-meta">
              <span class="badge">Node CLI</span>
              <span class="badge badge-soft">JavaScript</span>
            </div>
            <h3>packscope</h3>
            <p>{c.packscopeDesc}</p>
            <div class="project-actions">
              {/* TODO(i18n batch 3): product body copy is still English; page exists so links resolve. */}
              <a href={localizePath('/packscope', 'zh')} class="btn btn-primary">{c.learnMore}</a>
              <a href="https://github.com/awareride/packscope" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
                GitHub
              </a>
            </div>
          </div>
          <div class="project-preview" aria-hidden="true">
            <div class="terminal">
              <div class="terminal-header">
                <span></span><span></span><span></span>
              </div>
              <pre class="terminal-body"><code>$ npx packscope ./dist/app.js ./out

<span class="term-comment"># webpack/rspack output</span>
out/
├── header.js
├── webpack-runtime.js
├── runtime.js
├── index.js
├── modules/&lt;id&gt;.js
├── manifest.json
├── rebuild.js
└── package.json

$ node out/index.js --version
2.106.4</code></pre>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Principles -->
    <section id="principles" class="section section-alt">
      <div class="container">
        <div class="section-header">
          <p class="eyebrow">{c.principlesEyebrow}</p>
          <h2>{c.principlesTitle}</h2>
        </div>
        <ul class="principles-list">
          <li>
            <strong>{c.principle1Title}</strong>
            {c.principle1Body}
          </li>
          <li>
            <strong>{c.principle2Title}</strong>
            {c.principle2Body}
          </li>
          <li>
            <strong>{c.principle3Title}</strong>
            {c.principle3Body}
          </li>
          <li>
            <strong>{c.principle4Title}</strong>
            {c.principle4Body}
          </li>
        </ul>
      </div>
    </section>

    <!-- CTA -->
    <section class="section">
      <div class="container">
        <div class="cta-box">
          <h2>{c.ctaTitle}</h2>
          <p>{c.ctaBody}</p>
          <div class="cta-actions">
            <a href="https://github.com/awareride" class="btn btn-primary btn-large" target="_blank" rel="noopener noreferrer">
              {c.ctaGithubOrg}
            </a>
            <a href="mailto:hello@awareride.com" class="btn btn-secondary btn-large">hello@awareride.com</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
