---
// src/pages/zh/packscope/docs/index.astro
// Packscope docs overview page (locale: zh).
// Chinese index does not exist yet - renders English index as fallback.
import DocsLayout from '../../../../components/DocsLayout.astro';
import { getLocalizedDocIndex } from '../../../../lib/content';
import { buildAlternates } from '../../../../lib/i18n';

const page = await getLocalizedDocIndex('packscope', 'zh', '/zh/packscope/docs');
if (!page) return Astro.redirect('/zh/packscope');
const { Content, title, description, navItems, isFallback } = page;
const alternates = buildAlternates('/packscope/docs');
---

<DocsLayout
  title={title}
  description={description}
  sidebarTitle="Packscope 文档"
  navItems={navItems}
  locale="zh"
  isFallback={isFallback}
  basePath="/zh/packscope/docs"
  alternates={alternates}
>
  <Content />
</DocsLayout>
