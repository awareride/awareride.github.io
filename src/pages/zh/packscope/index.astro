---
// src/pages/zh/packscope/index.astro
// Packscope Product Page (locale: zh). Copy in lib/i18n.ts `packscope.zh`.
import Layout from '../../../components/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import { packscope as c, localizePath, buildAlternates, type Locale } from '../../../lib/i18n';

const locale: Locale = 'zh';
const ui = c[locale];
const docsHref = localizePath('/packscope/docs', locale);
const alternates = buildAlternates('/packscope');
---

<Layout title={ui.title} description={ui.description} locale={locale} alternates={alternates}>
  <Nav alternates={alternates} />

  <main>
    <!-- Product Hero -->
    <section class="product-hero">
      <div class="container">
        <div class="hero-badge" style="display:inline-block; font-size:0.85rem; font-weight:600; padding:0.25rem 0.9rem; border-radius:100px; background:var(--color-accent-subtle); color:var(--color-accent); margin-bottom:1.25rem;">
          {ui.heroBadge}
        </div>
        <h1>{ui.heroTitle}</h1>
        <p class="hero-lead">
          {ui.heroLead}
        </p>
        <div class="hero-actions">
          <a href="https://github.com/awareride/packscope" class="btn btn-primary" target="_blank" rel="noopener">{ui.starGithub}</a>
          <a href={docsHref} class="btn btn-secondary">{ui.documentation}</a>
        </div>

        <div class="terminal">
          <div class="terminal-header">
            <span></span><span></span><span></span>
            <span class="terminal-title" style="color:#6b6860; font-size:0.75rem; margin-left:0.5rem;">terminal</span>
          </div>
          <pre class="terminal-body"><code>$ npx packscope ./dist/app.js ./out

<span class="term-comment"># webpack/rspack output</span>
out/
├── header.js
├── webpack-runtime.js
├── runtime.js
├── index.js
├── modules/&lt;id&gt;.js
├── manifest.json
├── rebuild.js
└── package.json

$ node out/index.js --version
2.106.4</code></pre>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="section section-alt">
      <div class="container">
        <div class="section-header">
          <p class="eyebrow">{ui.featuresEyebrow}</p>
          <h2>{ui.featuresTitle}</h2>
        </div>
        <div class="feature-grid">
          <article class="feature-card">
            <h3>{ui.f1Title}</h3>
            <p>{ui.f1Body}</p>
          </article>
          <article class="feature-card">
            <h3>{ui.f2Title}</h3>
            <p>{ui.f2Body}</p>
          </article>
          <article class="feature-card">
            <h3>{ui.f3Title}</h3>
            <p>{ui.f3Body}</p>
          </article>
          <article class="feature-card">
            <h3>{ui.f4Title}</h3>
            <p>{ui.f4Body}</p>
          </article>
          <article class="feature-card">
            <h3>{ui.f5Title}</h3>
            <p>{ui.f5Body}</p>
          </article>
          <article class="feature-card">
            <h3>{ui.f6Title}</h3>
            <p>{ui.f6Body}</p>
          </article>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="section">
      <div class="container">
        <div class="section-header">
          <p class="eyebrow">{ui.internalsEyebrow}</p>
          <h2>{ui.internalsTitle}</h2>
        </div>
        <div class="steps">
          <div class="step">
            <div class="step-number">1</div>
            <div class="step-body">
              <h3>{ui.s1Title}</h3>
              <p>{ui.s1Body}</p>
            </div>
          </div>
          <div class="step">
            <div class="step-number">2</div>
            <div class="step-body">
              <h3>{ui.s2Title}</h3>
              <p>{ui.s2Body}</p>
            </div>
          </div>
          <div class="step">
            <div class="step-number">3</div>
            <div class="step-body">
              <h3>{ui.s3Title}</h3>
              <p>{ui.s3Body}</p>
            </div>
          </div>
          <div class="step">
            <div class="step-number">4</div>
            <div class="step-body">
              <h3>{ui.s4Title}</h3>
              <p>{ui.s4Body}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Usage -->
    <section class="section section-alt">
      <div class="container">
        <div class="section-header">
          <p class="eyebrow">{ui.quickStartEyebrow}</p>
          <h2>{ui.quickStartTitle}</h2>
        </div>
        <div class="usage-grid">
          <div class="usage-card">
            <h3>{ui.install}</h3>
            <pre><code>npm install</code></pre>
          </div>
          <div class="usage-card">
            <h3>{ui.unpackLocal}</h3>
            <pre><code>npx packscope ./dist/app.js ./out</code></pre>
          </div>
          <div class="usage-card">
            <h3>{ui.unpackUrl}</h3>
            <pre><code>npx packscope https://example.com/app.js ./out</code></pre>
          </div>
          <div class="usage-card">
            <h3>{ui.runTree}</h3>
            <pre><code>node out/index.js --version
node out/index.js --help</code></pre>
          </div>
          <div class="usage-card wide">
            <h3>{ui.options}</h3>
            <ul class="option-list">
              <li><code>--beautify</code> — pretty-print output (best-effort)</li>
              <li><code>--decompose</code> — extract classes / services / wrappers for navigation (ES modules)</li>
              <li><code>--rename</code> — rename wrapper params to <code>module</code>/<code>exports</code>/<code>require</code></li>
              <li><code>--fetch-assets</code> / <code>--no-fetch-assets</code> — control source-map / asset downloads</li>
              <li><code>--entry &lt;N&gt;</code> — force entry module id</li>
            </ul>
          </div>
          <div class="usage-card wide">
            <h3>{ui.rebuildAfter}</h3>
            <pre><code>echo "// patched" >> out/modules/92367.js
node out/rebuild.js bundle-patched.js
node bundle-patched.js --version</code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section">
      <div class="container">
        <div class="cta-box">
          <h2>{ui.ctaTitle}</h2>
          <p>{ui.ctaBody}</p>
          <div class="cta-actions">
            <a href="https://github.com/awareride/packscope" class="btn btn-primary btn-large" target="_blank" rel="noopener">
              {ui.starGithub}
            </a>
            <a href={docsHref} class="btn btn-secondary btn-large">
              {ui.readDocs}
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
