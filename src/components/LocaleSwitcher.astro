---
// src/components/LocaleSwitcher.astro
// Dropdown to switch between available translations of the current page.
// Receives `alternates` (map of locale -> URL) from the page via Layout.
// Only locales present in `alternates` are offered; a locale is omitted when
// the page has no version in that language (not even a fallback).
//
// Opens on hover/focus-within (desktop, progressive enhancement) and on click
// via the .open class (primary interaction, required for touch devices).
import { locales, localeLabel, type Locale } from '../lib/i18n';

export interface Props {
  alternates?: Partial<Record<Locale, string>>;
  current: Locale;
}

const { alternates = {}, current } = Astro.props;
const available = locales.filter((l) => alternates[l]);
const hidden = available.length <= 1;
---

{!hidden && (
  <div class="locale-switcher">
    <button
      class="locale-switcher-btn"
      type="button"
      aria-haspopup="true"
      aria-expanded="false"
      aria-controls="locale-switcher-menu"
    >
      <span class="locale-switcher-globe" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
          <circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20"/>
        </svg>
      </span>
      <span>{localeLabel(current)}</span>
    </button>
    <ul class="locale-switcher-menu" id="locale-switcher-menu" role="menu">
      {available.map((l) => (
        <li role="none">
          <a
            href={alternates[l]}
            role="menuitem"
            class:list={['locale-switcher-item', { active: l === current }]}
            hreflang={l}
          >
            {localeLabel(l)}
          </a>
        </li>
      ))}
    </ul>
  </div>
)}

<script>
  // Click-to-open for touch devices (hover/focus-within is a desktop bonus).
  document.querySelectorAll<HTMLElement>('.locale-switcher').forEach((sw) => {
    const btn = sw.querySelector<HTMLButtonElement>('.locale-switcher-btn');
    if (!btn) return;
    const setOpen = (open: boolean) => {
      sw.classList.toggle('open', open);
      btn.setAttribute('aria-expanded', String(open));
    };
    btn.addEventListener('click', () => {
      setOpen(!sw.classList.contains('open'));
    });
    // Close when a menu item is chosen.
    sw.querySelectorAll('.locale-switcher-item').forEach((a) => {
      a.addEventListener('click', () => setOpen(false));
    });
    // Close on Escape.
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });
    // Close on outside click.
    document.addEventListener('click', (e) => {
      if (!sw.contains(e.target as Node)) setOpen(false);
    });
  });
</script>
