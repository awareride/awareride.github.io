---
// src/components/DocsLayout.astro
// Layout for documentation pages — reuses site shell (Layout/Nav/Footer)
// and adds a sidebar + content region. Markdown uses the shared .prose styles.
import Layout from './Layout.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';

export interface NavItem {
  href: string;
  label: string;
}

export interface Props {
  title: string;
  description?: string;
  sidebarTitle?: string;
  productName?: string;
  productHref?: string;
  navItems?: NavItem[];
  basePath?: string;
}

const {
  title,
  description,
  sidebarTitle = 'Docs',
  productName = 'Packscope',
  productHref = '/packscope',
  navItems = [],
  basePath = '/packscope/docs',
} = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '');
---

<Layout title={title} description={description}>
  <Nav />

  <main>
    <div class="docs-page">
      <aside class="docs-sidebar">
        <h4>{sidebarTitle}</h4>
        {
          navItems.length > 0 ? (
            navItems.map(item => (
              <a
                href={item.href}
                class:list={[{ active: currentPath === item.href.replace(/\/$/, '') }]}
              >
                {item.label}
              </a>
            ))
          ) : (
            <p style="color: var(--color-text-muted); font-size: 0.85rem;">No pages yet.</p>
          )
        }
      </aside>

      <div class="docs-main">
        <div class="docs-breadcrumb">
          <a href="/">Home</a> / <a href={productHref}>{productName}</a> / <span>{title}</span>
        </div>

        <article class="prose">
          <h1>{title}</h1>
          <slot />
        </article>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
