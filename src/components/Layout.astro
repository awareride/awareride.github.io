---
// src/components/Layout.astro
import '../styles/global.css';
import { defaultLocale, type Locale } from '../lib/i18n';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  locale?: Locale;
  alternates?: Partial<Record<Locale, string>>;
}

const { title, description, ogImage, locale = defaultLocale, alternates = {} } = Astro.props;
const siteName = 'AwareRide';
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;
const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const abs = (p: string) => (p.startsWith('http') ? p : `${site}${p}`);
---

<!doctype html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description || 'Open source exploring human perception, spatial intelligence, and wellness.'} />
  <meta name="theme-color" content="#faf9f7" />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description || ''} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={siteName} />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <!-- hreflang alternates -->
  {alternates.en && <link rel="alternate" hreflang="en" href={abs(alternates.en)} />}
  {alternates.zh && <link rel="alternate" hreflang="zh" href={abs(alternates.zh)} />}
  {alternates.en && <link rel="alternate" hreflang="x-default" href={abs(alternates.en)} />}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
</head>
<body>
  <slot />
</body>
</html>
